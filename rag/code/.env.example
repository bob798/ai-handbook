# ============================================
# RAG Demo 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ============================================
# 硅基流动 SiliconFlow（推荐国内用户）
# 注册地址：https://siliconflow.cn
# 免费额度大，BGE-M3 embedding 质量好
# ============================================
SILICONFLOW_API_KEY=your_siliconflow_key_here

# ============================================
# 智谱 AI ZhipuAI
# 注册地址：https://open.bigmodel.cn
# ============================================
ZHIPU_API_KEY=your_zhipu_key_here

# ============================================
# 阿里云 DashScope（通义千问）
# 注册地址：https://dashscope.aliyun.com
# ============================================
DASHSCOPE_API_KEY=your_dashscope_key_here

# ============================================
# OpenAI
# ============================================
OPENAI_API_KEY=your_openai_key_here

# ============================================
# 当前使用的提供商
# 选项: "siliconflow" | "zhipu" | "qwen" | "openai"
# ============================================
PROVIDER=siliconflow

# ============================================
# 可选：自定义模型名称
# 如果不设置，将使用下方各提供商的默认模型
# ============================================

# Embedding 模型（用于文本向量化）
# 硅基流动默认: BAAI/bge-m3
# 智谱默认: embedding-3
# 通义默认: text-embedding-v3
# OpenAI 默认: text-embedding-3-small
# EMBED_MODEL=BAAI/bge-m3

# Chat 模型（用于对话生成）
# 硅基流动默认: Qwen/Qwen2.5-7B-Instruct
# 智谱默认: glm-4-flash
# 通义默认: qwen-plus
# OpenAI 默认: gpt-4o-mini
# CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
