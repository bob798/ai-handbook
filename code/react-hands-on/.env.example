# Copy this file to `.env` and fill in the key(s) for the backend you use.
# run_react.py auto-loads .env via python-dotenv.

# --- Anthropic (default backend) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- DeepSeek official ---
# DEEPSEEK_API_KEY=sk-...

# --- VolcEngine (火山引擎方舟) ---
# VOLCENGINE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
